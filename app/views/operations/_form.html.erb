<%= form_with(model: @operation, html: { class: "compta-form" }, data: { controller: "subcategory-select" }) do |f| %>
  <% if @operation.errors.any? %>
    <div class="errors-box">
      <h3><%= pluralize(@operation.errors.count, "erreur") %> :</h3>
      <ul>
        <% @operation.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :category_id, "Catégorie", class: "form-label" %>
    <%= f.collection_select :category_id, @categories, :id, :name,
        { prompt: "Sélectionner une catégorie" },
        { class: "form-input", data: { subcategory_select_target: "category", action: "change->subcategory-select#loadSubcategories" } } %>
  </div>

  <div class="form-group">
    <%= f.label :subcategory_id, "Sous-catégorie", class: "form-label" %>
    <%= f.select :subcategory_id,
        options_for_select(@subcategories.map { |s| [s.name, s.id] }, @operation.subcategory_id),
        { prompt: "Sélectionner une sous-catégorie" },
        { class: "form-input", data: { subcategory_select_target: "subcategory" } } %>
  </div>

  <div class="form-group">
    <%= f.label :amount, "Montant (€)", class: "form-label" %>
    <%= f.number_field :amount, step: 0.01, min: 0.01, placeholder: "0,00", class: "form-input form-input-mono" %>
  </div>

  <div class="form-group">
    <%= f.label :payment_date, "Date de paiement", class: "form-label" %>
    <%= f.date_field :payment_date, value: @operation.payment_date || Date.current, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= f.label :observation, "Observation", class: "form-label" %>
    <%= f.text_field :observation, maxlength: 80, placeholder: "Note libre (80 caractères max)", class: "form-input" %>
    <span class="form-hint">80 caractères maximum</span>
  </div>

  <div class="form-actions">
    <%= f.submit @operation.persisted? ? "Modifier l'opération" : "Enregistrer l'opération", class: "btn btn-primary btn-full" %>
  </div>
<% end %>
