<div class="page-wrapper">
  <h1>Catégories & Sous-catégories</h1>
  <p class="page-subtitle">Gérer l'organisation des opérations</p>

  <!-- Formulaire ajout catégorie -->
  <div class="card card-elevated section-block">
    <h2>Ajouter une catégorie</h2>
    <%= form_with(model: @category, url: categories_path, class: "inline-form") do |f| %>
      <div class="inline-form-fields">
        <div class="form-group">
          <%= f.label :name, "Nom", class: "form-label" %>
          <%= f.text_field :name, placeholder: "Nom de la catégorie", class: "form-input" %>
        </div>
        <div class="form-group">
          <%= f.label :operation_type, "Type", class: "form-label" %>
          <%= f.select :operation_type, [["Dépense (débit)", "debit"], ["Revenu (crédit)", "credit"]], {}, class: "form-input" %>
        </div>
        <div class="form-group form-group-btn">
          <%= f.submit "Ajouter", class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Liste des catégories -->
  <% Category.debits.includes(:subcategories).order(:name).each_with_index do |cat, i| %>
    <div class="card category-card" style="animation-delay: <%= i * 0.05 %>s">
      <div class="category-header">
        <div class="category-title-group">
          <span class="operation-badge-lg badge-debit">Dépense</span>
          <h3><%= cat.name %></h3>
        </div>
        <div class="category-actions">
          <%= link_to "Modifier", edit_category_path(cat), class: "btn btn-sm btn-secondary" %>
          <%= link_to "Supprimer", category_path(cat), data: { turbo_method: :delete, turbo_confirm: "Supprimer la catégorie « #{cat.name} » ?" }, class: "btn btn-sm btn-danger" %>
        </div>
      </div>

      <div class="subcategories-list">
        <% cat.subcategories.order(:name).each do |sub| %>
          <div class="subcategory-item">
            <span class="subcategory-name"><%= sub.name %></span>
            <% if sub.operations.empty? %>
              <%= link_to "×", category_subcategory_path(cat, sub), data: { turbo_method: :delete, turbo_confirm: "Supprimer « #{sub.name} » ?" }, class: "subcategory-delete" %>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Ajout sous-catégorie -->
      <%= form_with(model: [cat, Subcategory.new], class: "add-subcategory-form") do |f| %>
        <div class="inline-form-fields">
          <%= f.text_field :name, placeholder: "Nouvelle sous-catégorie...", class: "form-input form-input-sm" %>
          <%= f.submit "+", class: "btn btn-sm btn-primary" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% Category.credits.includes(:subcategories).order(:name).each_with_index do |cat, i| %>
    <div class="card category-card" style="animation-delay: <%= (i + Category.debits.count) * 0.05 %>s">
      <div class="category-header">
        <div class="category-title-group">
          <span class="operation-badge-lg badge-credit">Revenu</span>
          <h3><%= cat.name %></h3>
        </div>
        <div class="category-actions">
          <%= link_to "Modifier", edit_category_path(cat), class: "btn btn-sm btn-secondary" %>
          <%= link_to "Supprimer", category_path(cat), data: { turbo_method: :delete, turbo_confirm: "Supprimer la catégorie « #{cat.name} » ?" }, class: "btn btn-sm btn-danger" %>
        </div>
      </div>

      <div class="subcategories-list">
        <% cat.subcategories.order(:name).each do |sub| %>
          <div class="subcategory-item">
            <span class="subcategory-name"><%= sub.name %></span>
            <% if sub.operations.empty? %>
              <%= link_to "×", category_subcategory_path(cat, sub), data: { turbo_method: :delete, turbo_confirm: "Supprimer « #{sub.name} » ?" }, class: "subcategory-delete" %>
            <% end %>
          </div>
        <% end %>
      </div>

      <%= form_with(model: [cat, Subcategory.new], class: "add-subcategory-form") do |f| %>
        <div class="inline-form-fields">
          <%= f.text_field :name, placeholder: "Nouvelle sous-catégorie...", class: "form-input form-input-sm" %>
          <%= f.submit "+", class: "btn btn-sm btn-primary" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="back-link">
    <%= link_to "← Retour à l'accueil", root_path %>
  </div>
</div>
